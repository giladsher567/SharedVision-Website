{
    "redirects": [
        {
            "source": "/en",
            "destination": "/en/",
            "permanent": true
        }
    ],
    "rewrites": [
        {
            "source": "/",
            "has": [{ "type": "host", "value": "verticrop.sharedvisionai.org" }],
            "destination": "/vertical-crop"
        },
        {
            "source": "/services",
            "destination": "/services.html"
        },
        {
            "source": "/contact",
            "destination": "/contact.html"
        },
        {
            "source": "/lead",
            "destination": "/lead.html"
        },
        {
            "source": "/vertical-crop",
            "destination": "/vertical-crop.html"
        },
        {
            "source": "/en/services",
            "destination": "/en/services.html"
        },
        {
            "source": "/en/contact",
            "destination": "/en/contact.html"
        },
        {
            "source": "/en/",
            "destination": "/en/index.html"
        }
    ]
}